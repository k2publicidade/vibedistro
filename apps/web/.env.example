# VibeDistro Web — Frontend env vars
# Copy to .env.local for local dev. All vars are PUBLIC (exposed to browser).

# URL base do NestJS API em produção (ex: https://api.vibedistro.com)
NEXT_PUBLIC_API_URL=http://localhost:3001

# URL canônica da própria web app (ex: https://app.vibedistro.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Branding exibido na UI
NEXT_PUBLIC_APP_NAME=VibeDistro

# Revelator environment flag: sandbox | production
NEXT_PUBLIC_REVELATOR_ENVIRONMENT=sandbox
