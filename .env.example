# ============================================================
# VibeDistro — Environment Variables Reference
# Copy to .env and fill in the values
# ============================================================

# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://vibedistro:vibedistro@localhost:5432/vibedistro

# ─────────────────────────────────────────────
# REDIS (BullMQ + Caching)
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# JWT Authentication
# ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=changeme-jwt-secret-minimum-32-characters-long
JWT_REFRESH_SECRET=changeme-refresh-secret-minimum-32-characters-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# API Server
# ─────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Comma-separated allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────
# Storage (Assets: audio, covers)
# ─────────────────────────────────────────────
# Options: s3, r2, local
STORAGE_PROVIDER=local

# AWS S3 / Cloudflare R2
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_BUCKET=vibedistro-assets
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_URL=

# ─────────────────────────────────────────────
# Revelator Integration
# ─────────────────────────────────────────────
# Set to false to run without Revelator (mocked provider will be used)
REVELATOR_ENABLED=false

# sandbox | production
REVELATOR_ENVIRONMENT=sandbox

# Sandbox credentials (obtain from Revelator developer portal)
REVELATOR_API_URL=https://api.sandbox.revelator.com/v1
REVELATOR_AUTH_URL=https://auth.sandbox.revelator.com/oauth/token
REVELATOR_CLIENT_ID=
REVELATOR_CLIENT_SECRET=
REVELATOR_WEBHOOK_SECRET=
# Your distributor account ID in Revelator
REVELATOR_ACCOUNT_ID=

# ─────────────────────────────────────────────
# Web App (Next.js — prefix NEXT_PUBLIC_ for browser exposure)
# ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=VibeDistro
# Exposed to UI so the sandbox badge can be displayed
NEXT_PUBLIC_REVELATOR_ENVIRONMENT=sandbox

# ─────────────────────────────────────────────
# Worker (BullMQ concurrency)
# ─────────────────────────────────────────────
WORKER_SYNC_CONCURRENCY=5
WORKER_WEBHOOK_CONCURRENCY=10
WORKER_ANALYTICS_CONCURRENCY=3

# ─────────────────────────────────────────────
# Email (optional — for invite and notification emails)
# ─────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@vibedistro.com
