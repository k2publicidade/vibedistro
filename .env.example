# ============================================================
# VibeDistro — Environment Variables Reference
# Copy to .env and fill in the values
# ============================================================

# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://vibedistro:vibedistro@localhost:5432/vibedistro

# ─────────────────────────────────────────────
# REDIS (BullMQ + Caching)
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# JWT Authentication
# ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=changeme-jwt-secret-minimum-32-characters-long
JWT_REFRESH_SECRET=changeme-refresh-secret-minimum-32-characters-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# API Server
# ─────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Comma-separated allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────
# Storage (Assets: audio, covers)
# ─────────────────────────────────────────────
# Options: s3, r2, local
STORAGE_PROVIDER=local

# AWS S3 / Cloudflare R2
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_BUCKET=vibedistro-assets
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_URL=

# ─────────────────────────────────────────────
# Revelator Integration
# Auth: POST /account/loginpartner { partnerApiKey, partnerUserId } → Bearer token
# Docs: https://api.revelator.com/swagger
# ─────────────────────────────────────────────
# Set to true to enable Revelator API calls (false = no external calls made)
REVELATOR_ENABLED=true

# sandbox | production (both use https://api.revelator.com)
REVELATOR_ENVIRONMENT=sandbox

# API base URL (same host for sandbox and production)
REVELATOR_API_URL=https://api.revelator.com

# Partner API credentials (from Revelator partner portal)
REVELATOR_PARTNER_API_KEY=53ad6a23-5436-4461-a523-0d3b90b82701
REVELATOR_PARTNER_USER_ID=XASKz2yXy8VBFz8Oe8Adlz1Vl3Dt4k

# Optional: pre-set enterpriseId (resolved from login if omitted)
# Sandbox: 893945
REVELATOR_ENTERPRISE_ID=893945

# HMAC secret for webhook signature verification (set in Revelator webhook config)
REVELATOR_WEBHOOK_SECRET=

# ─────────────────────────────────────────────
# Web App (Next.js — prefix NEXT_PUBLIC_ for browser exposure)
# ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=VibeDistro
# Exposed to UI so the sandbox badge can be displayed
NEXT_PUBLIC_REVELATOR_ENVIRONMENT=sandbox

# ─────────────────────────────────────────────
# Worker (BullMQ concurrency)
# ─────────────────────────────────────────────
WORKER_SYNC_CONCURRENCY=5
WORKER_WEBHOOK_CONCURRENCY=10
WORKER_ANALYTICS_CONCURRENCY=3

# ─────────────────────────────────────────────
# Email (optional — for invite and notification emails)
# ─────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@vibedistro.com
